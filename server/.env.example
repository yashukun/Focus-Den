# Copy to server/.env for real use. Local dev runs fine without it (defaults below).

# REQUIRED in production — the server refuses to start without it.
# Generate one: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

PORT=8787
# Localhost-only by default; deployments set 0.0.0.0 (the Dockerfile does).
HOST=127.0.0.1

# SQLite by default (data/focus-den.db). Point at a .json path to use the
# legacy JSON-file store instead; a fresh SQLite db imports data/db.json once.
DB_PATH=./data/focus-den.db

# Directory of the built frontend to serve (single-box deploy). Defaults to
# ../dist; skipped automatically when it doesn't exist (e.g. local dev).
# STATIC_DIR=../dist

# Set true when behind a reverse proxy / PaaS so rate limiting sees real client
# IPs from X-Forwarded-For. Defaults to true when NODE_ENV=production.
# TRUST_PROXY=true

# Pin CORS to your real origin in production (any origin is allowed if unset,
# which is fine for dev / same-origin single-box deploys).
# CORS_ORIGIN=https://focus.example.com

# The single admin account name — only this profile sees the testing tools
# (+points) and "reset everything". Unset: in dev everyone is admin; in
# production nobody is.
# ADMIN_USER=yash
